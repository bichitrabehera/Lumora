  "faqs": [
    {
      "question": "What is this site for?",
      "answer": "It is a landing page concept for personalized celebration websites that can be shared as a single link."
    },
    {
      "question": "Can the pages be customized?",
      "answer": "Yes. The idea is to swap colors, copy, photos, and a few sections so every page feels personal."
    },
    {
      "question": "Is this mobile friendly?",
      "answer": "The layout is built to stack cleanly on smaller screens so the experience stays polished on phones."
    },
    {
      "question": "Can I turn this into a real product site?",
      "answer": "Yes. You can replace the sample content with your own products, pricing, and checkout flow later."
    }
